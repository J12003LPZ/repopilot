# Neon Postgres (Vercel Marketplace). Use the pooled connection string.
DATABASE_URL=

# GitHub API token (server-side only). A classic or fine-grained read token.
GITHUB_TOKEN=

# Salt for hashing visitor IPs (server-side only).
IP_HASH_SALT=

# Cloudflare AI roadmap worker (server-side only). Optional — falls back to template.
CLOUDFLARE_AI_URL=
CLOUDFLARE_AI_SECRET=

# Public base URL for building shareable report links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
