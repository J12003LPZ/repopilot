# Neon Postgres (Vercel Marketplace). Use the pooled connection string.
DATABASE_URL=

# GitHub API token (server-side only). A classic or fine-grained read token.
GITHUB_TOKEN=

# Salt for hashing visitor IPs (server-side only).
IP_HASH_SALT=

# Cloudflare Workers AI (server-side only). Optional — the roadmap falls back to a
# deterministic template if these are unset. Called via the Cloudflare REST API.
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
# Optional model override (default: @cf/meta/llama-4-scout-17b-16e-instruct,
# a 131K-context model for broad repo coverage). Must be a real Workers AI slug —
# Cloudflare does NOT host Anthropic/OpenAI models. To trade context for slightly
# sharper coding analysis, set: @cf/meta/llama-3.3-70b-instruct-fp8-fast (24K).
# CLOUDFLARE_MODEL=@cf/meta/llama-4-scout-17b-16e-instruct

# Public base URL for building shareable report links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
